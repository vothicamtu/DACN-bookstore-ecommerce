# =========================================================================
# Backend (Spring Boot / Maven) .gitignore
# =========================================================================

# -------------------------------------------------------------------------
# Local/Sensitive Configurations (CRITICAL)
# -------------------------------------------------------------------------
# Local application properties (preserves user's custom ignore rule)
src/main/resources/application.properties
src/main/resources/application-local.properties
src/main/resources/application-dev.properties
src/main/resources/application*.properties
src/main/resources/application*.yml
src/main/resources/application*.yaml

# -------------------------------------------------------------------------
# Build Outputs & Package Formats
# -------------------------------------------------------------------------
target/
bin/
build/
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
out/

# -------------------------------------------------------------------------
# IDE / Editor Files (Java-Specific)
# -------------------------------------------------------------------------
.classpath
.project
.settings/
.factorypath
*.iml
*.ipr
*.iws
.idea/
.vscode/

# -------------------------------------------------------------------------
# Tools & Crash Logs
# -------------------------------------------------------------------------
hs_err_pid*
replay_pid*
.attach_pid*

# Logs
*.log
*.err.log

# Node
node_modules/
dist/

# OS
.DS_Store
Thumbs.db
